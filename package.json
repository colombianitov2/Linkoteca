{
  "name": "linkoteca",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Biblioteca visual de enlaces con carpetas, vista previa y sincronizacion.",
  "author": "Ernesto Pernett",
  "repository": {
    "type": "git",
    "url": "https://github.com/colombianitov2/Linkoteca.git"
  },
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-linkoteca.ps1",
    "serve": "node src/server.js",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-linkoteca.ps1",
    "dev": "node src/server.js",
    "desktop": "electron electron/main.cjs",
    "check": "node --check src/server.js && node --check public/app.js && node --check electron/main.cjs && node --test tests/*.test.cjs",
    "test": "node --test tests/*.test.cjs",
    "dist:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-windows.ps1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^5.1.0",
    "lucide-static": "^1.16.0"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.wolframica.linkoteca",
    "productName": "Linkoteca",
    "electronVersion": "42.3.0",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "colombianitov2",
      "repo": "Linkoteca"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "scripts/**/*",
      "!data/*.json",
      "package.json",
      "README.md"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
